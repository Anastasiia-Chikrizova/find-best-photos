# Шаблон переменных окружения. Скопируй в .env и впиши значения:
#   cp .env.example .env
# .env в .gitignore и .dockerignore — реальные ключи в репозиторий/образ не попадут.

# --- Cloudflare R2 (опционально; без них загрузка идёт multipart на бекенд) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# R2_PREFIX=uploads
# R2_PUT_EXPIRES=3600


# --- Лимиты и тюнинг (необязательно, значения по умолчанию подходят) ---
# MAX_FILE_MB=80
# MAX_FILES_PER_REQUEST=50
# ANALYZE_MAX_DIM=1280
# ANALYZE_WORKERS=
# UPLOAD_CONCURRENCY=4
# SHARPNESS_REF=500
# NOISE_REF=12
